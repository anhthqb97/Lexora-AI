# Environment Variables — Local Template

# Copy to .env.local (gitignored). See docs/engineering/secrets-policy.md

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/lexora

# --- Redis (Upstash REST or local Docker) ---
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=local-dev-token

# --- Auth ---
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- AI — MVP staging/prod ---
OPENAI_API_KEY=
AI_GATEWAY_URL=http://localhost:8081

# --- AI — local dev only ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Speech — local dev (no Azure) ---
SPEECH_PROVIDER=mock

# --- Speech — staging/prod (uncomment after P0-T16) ---
# SPEECH_SERVICE_URL=http://localhost:8082
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=southeastasia
# WHISPER_LOCAL_URL=http://localhost:8001

# --- Email (P0-T18) ---
# RESEND_API_KEY=

# --- SMS OTP (P0-T19) ---
# SMS_PROVIDER_API_KEY=

# --- Payments (sandbox) ---
MOMO_PARTNER_CODE=
MOMO_SECRET_KEY=
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# --- Monitoring (P1-T005) ---
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
